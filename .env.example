# -----------------------------------------------------------------------------
# Configuración de la base de datos
# -----------------------------------------------------------------------------
DB_USERNAME=DB_USERNAME
DB_PASSWORD=DB_PASSWORD
DB_URL=jdbc:postgresql://localhost:5432/facturacion
DB_NAME=DB_NAME

# Host y puerto de la base de datos
# NOTA: Para desarrollo local usar 'localhost', para Docker usar 'postgres'
# El docker-compose.yml sobrescribe este valor automáticamente
DB_HOST=localhost
DB_PORT=5432

# -----------------------------------------------------------------------------
# VAULT (HashiCorp Vault)
# -----------------------------------------------------------------------------
VAULT_ADDR=http://127.0.0.1:8200
VAULT_ROLE_ID=VAULT_ROLE_ID
VAULT_SECRET_ID=VAULT_SECRET_ID

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
# Obligatorio en producción. En dev hay un fallback inseguro en application.yaml.
JWT_SECRET=CAMBIAR-EN-PRODUCCION

# -----------------------------------------------------------------------------
# Resend (correo transaccional)
# -----------------------------------------------------------------------------
# API key de tu cuenta en resend.com — sin fallback, el app no arranca si falta.
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXX
# Dirección remitente verificada en Resend. Default dev: onboarding@resend.dev (sandbox).
RESEND_FROM_EMAIL=onboarding@resend.dev

# -----------------------------------------------------------------------------
# Oracle Object Storage (OCI)
# -----------------------------------------------------------------------------
# Namespace de tu tenancy — asignado por Oracle, se obtiene en la consola OCI
# (Object Storage > Namespace). Sin fallback, el app no arranca si falta.
OCI_OBJECT_STORAGE_NAMESPACE=NAMESPACE_DE_TU_TENANCY
# Nombre del bucket donde se almacenan los comprobantes cifrados.
OCI_OBJECT_STORAGE_BUCKET=fractall-comprobantes
# Región OCI donde vive el bucket.
OCI_OBJECT_STORAGE_REGION=mx-queretaro-1
