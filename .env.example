# -----------------------------------------------------------------------------
# Configuración de la base de datos
# -----------------------------------------------------------------------------
DB_USERNAME=DB_USERNAME
DB_PASSWORD=DB_PASSWORD
DB_URL=jdbc:postgresql://localhost:5432/facturacion
DB_NAME=DB_NAME

# Host y puerto de la base de datos
# NOTA: Para desarrollo local usar 'localhost', para Docker usar 'postgres'
# El docker-compose.yml sobrescribe este valor automáticamente
DB_HOST=localhost
DB_PORT=5432

# -----------------------------------------------------------------------------
# VAULT (HashiCorp Vault)
# -----------------------------------------------------------------------------
VAULT_ADDR=http://127.0.0.1:8200
VAULT_ROLE_ID=VAULT_ROLE_ID
VAULT_SECRET_ID=VAULT_SECRET_ID